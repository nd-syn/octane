# --- Required ---

# "dev" or "prod". In "prod", the app refuses to start if secrets are missing
# or too short. In "dev", missing values get safe placeholders.
ENV=dev

# Async SQLite URL. On Render, default is /var/data/messaging.db
DATABASE_URL=sqlite+aiosqlite:///./messaging.db

# 32+ random bytes, base64-encoded. Generate with `python scripts/genkey.py`.
# In prod, both of these MUST be set. NEVER reuse a key across environments.
JWT_SECRET=replace-me-with-output-of-genkey
MASTER_KEY=replace-me-with-output-of-genkey

# Comma-separated CORS origins. No wildcards.
# Example for local dev: http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Optional ---

# 15 minutes, in seconds. Access-token lifetime.
ACCESS_TOKEN_TTL=900

# 30 days, in seconds. Refresh-token lifetime.
REFRESH_TOKEN_TTL=2592000

# S3-compatible URL for SQLite backups, e.g. s3://bucket-name
# Required only if you want to run scripts/backup_db.py.
BACKUP_S3_URL=

# Standard S3 / B2 credentials (used by scripts/backup_db.py only)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com
# AWS_REGION=us-west-002
